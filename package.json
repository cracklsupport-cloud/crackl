{
  "name": "crackl",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:web": "expo export --platform web",
    "doctor": "npx expo-doctor",
    "audit:prod": "npm audit --omit=dev",
    "smoke:browser": "npx --yes -p playwright node scripts/browser-smoke.js",
    "verify": "npm run doctor && npm run audit:prod && npm run build:web"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-three/fiber": "^9.5.0",
    "expo": "~55.0.26",
    "expo-apple-authentication": "~55.0.13",
    "expo-asset": "~55.0.17",
    "expo-audio": "~55.0.14",
    "expo-auth-session": "~55.0.16",
    "expo-crypto": "~55.0.15",
    "expo-image-picker": "~55.0.20",
    "expo-linear-gradient": "~55.0.14",
    "expo-status-bar": "~55.0.6",
    "expo-web-browser": "~55.0.16",
    "gsap": "^3.14.2",
    "motion": "^12.38.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-web": "^0.21.0",
    "three": "^0.183.2",
    "three.js": "^0.77.0"
  },
  "private": true,
  "overrides": {
    "postcss": "^8.5.10",
    "uuid": "^11.1.1"
  },
  "devDependencies": {
    "@types/react": "~19.2.10",
    "playwright": "^1.60.0",
    "typescript": "~5.9.2"
  }
}

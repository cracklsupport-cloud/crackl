# Runtime
NODE_ENV=development
PORT=3000

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# JWT/Admin secrets
# Production JWT_SECRET should be at least 32 random characters.
JWT_SECRET=
# Optional JWT lifetime. Shorter is safer for production; keep 30d if you want long-lived app sessions.
AUTH_TOKEN_TTL=30d
ADMIN_SECRET=

# Browser/client origins allowed to call the API.
# Production example:
# ALLOWED_ORIGINS=https://crackl.app,https://www.crackl.app
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:3000,https://crackl.app

# Trusted origins for riddle media URLs.
# Defaults include SUPABASE_URL origin. Add CDN origins if you use one.
# ALLOWED_MEDIA_ORIGINS=https://pblyedoyxcxuqdhgnljv.supabase.co,https://cdn.crackl.app
ALLOWED_MEDIA_ORIGINS=

# OAuth/email integrations
GOOGLE_CLIENT_ID=
APPLE_CLIENT_ID=
EMAIL_USER=
EMAIL_PASS=

# Optional test override
SMOKE_BACKEND_URL=http://localhost:3000

# AI semantic answer judge (backend only)
# auto = OpenAI if OPENAI_API_KEY is present, otherwise Gemini if GEMINI_API_KEY is present,
# otherwise deterministic fallback only.
ANSWER_CHECK_PROVIDER=auto
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
# For low-cost answer checking, set ANSWER_CHECK_PROVIDER=gemini and use:
# ANSWER_CHECK_MODEL=gemini-2.5-flash-lite
ANSWER_CHECK_MODEL=
ANSWER_CHECK_TIMEOUT_MS=4500
ANSWER_CHECK_MAX_OUTPUT_TOKENS=320

# Optional Gemini fallback/provider
GEMINI_API_KEY=
